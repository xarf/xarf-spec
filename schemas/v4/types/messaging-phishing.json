{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://xarf.org/schemas/v4/types/messaging-phishing.json",
	"title": "XARF v4 Messaging - Phishing Type Schema",
	"description": "Schema for phishing email reports - malicious messages for revealing sensitive information or performing harmful actions",
	"allOf": [
		{
			"$ref": "../xarf-core.json"
		},
		{
			"type": "object",
			"properties": {
				"category": {
					"const": "messaging"
				},
				"type": {
					"const": "phishing"
				},
				"evidence_source": {
					"type": "string",
					"enum": [
						"spamtrap",
						"user_complaint",
						"automated_filter",
						"honeypot",
						"content_analysis",
						"reputation_feed"
					],
					"x-recommended": true,
					"description": "RECOMMENDED: Source of phishing evidence"
				},
				"protocol": {
					"type": "string",
					"enum": [
						"smtp",
						"sms",
						"whatsapp",
						"telegram",
						"signal",
						"chat",
						"social_media",
						"push_notification",
						"other"
					],
					"description": "REQUIRED: Communication protocol used for phishing delivery"
				},
				"smtp_from": {
					"type": "string",
					"format": "email",
					"description": "REQUIRED: SMTP envelope sender address (required when protocol=smtp)",
					"examples": [
						"phishing@example.com",
						"noreply@malicious-domain.example"
					]
				},
				"smtp_to": {
					"type": "string",
					"format": "email",
					"x-recommended": true,
					"description": "RECOMMENDED: SMTP envelope recipient address",
					"examples": [
						"victim@example.org",
						"phishing@malicious-domain.example"
					]
				},
				"subject": {
					"type": "string",
					"maxLength": 500,
					"x-recommended": true,
					"description": "RECOMMENDED: Message subject line",
					"examples": [
						"Urgent: Account Verification Required",
						"Your package is ready for delivery",
						"Limited Time Offer - Act Now!"
					]
				},
				"sender_name": {
					"type": "string",
					"maxLength": 200,
					"description": "OPTIONAL: Display name of the sender",
					"examples": [
						"Customer Support",
						"No Reply",
						"Sales Team"
					]
				},
				"message_id": {
					"type": "string",
					"maxLength": 200,
					"x-recommended": true,
					"description": "RECOMMENDED: Message ID from headers - helps with deduplication",
					"examples": [
						"<abc123@example.com>",
						"msg_1234567890"
					]
				},
				"user_agent": {
					"type": "string",
					"maxLength": 200,
					"description": "OPTIONAL: User agent string from message headers",
					"examples": [
						"Outlook 16.0",
						"bulk_mailer_v2.1"
					]
				},
				"recipient_count": {
					"type": "integer",
					"minimum": 1,
					"description": "OPTIONAL: Number of recipients for bulk phishing campaigns"
				},
				"language": {
					"type": "string",
					"pattern": "^[a-z]{2}(-[A-Z]{2})?$",
					"description": "OPTIONAL: Primary language of message content (ISO 639-1)",
					"examples": [
						"en",
						"es",
						"de",
						"ja",
						"en-US"
					]
				},
				"phishing_indicators": {
					"type": "object",
					"properties": {
						"suspicious_links": {
							"type": "array",
							"items": {
								"type": "string",
								"format": "uri"
							},
							"description": "OPTIONAL: Suspicious URLs found in the message"
						},
						"commercial_content": {
							"type": "boolean",
							"description": "OPTIONAL: Whether message contains commercial offers"
						},
						"bulk_characteristics": {
							"type": "boolean",
							"description": "OPTIONAL: Whether message shows bulk mailing characteristics"
						}
					},
					"description": "OPTIONAL: Indicators specific to phishing detection",
					"additionalProperties": false
				}
			},
			"required": [
				"protocol"
			],
			"if": {
				"properties": {
					"protocol": {
						"const": "smtp"
					}
				}
			},
			"then": {
				"required": [
					"smtp_from",
					"source_port"
				]
			}
		}
	],
	"examples": [
		{
			"xarf_version": "4.2.0",
			"report_id": "123e4567-e89b-12d3-a456-426614174000",
			"timestamp": "2024-01-15T14:30:25Z",
			"reporter": {
				"org": "Phishing Reporting Service",
				"contact": "reports@phishing-reports.example",
				"domain": "phishing-reports.example"
			},
			"sender": {
				"org": "Phishing Reporting Service",
				"contact": "reports@phishing-reports.example",
				"domain": "phishing-reports.example"
			},
			"source_identifier": "192.0.2.123",
			"source_port": 25,
			"category": "messaging",
			"type": "phishing",
			"protocol": "smtp",
			"smtp_from": "fake@example.com",
			"subject": "Urgent: Verify Your Account",
			"evidence_source": "user_complaint",
			"evidence": [
				{
					"content_type": "message/rfc822",
					"description": "Complete phishing email with headers",
					"payload": "UmVjZWl2ZWQ6IGZyb20gW3BoaXNoaW5nZXIuZXhhbXBsZS5jb21d..."
				}
			],
			"tags": [
				"phishing:commercial",
				"phishing:urgent",
				"phishing:social_engineering"
			],
			"confidence": 0.92
		}
	]
}
